# Database Credentials
# IMPORTANT: Change these in production! Use AWS Secrets Manager or similar.
MONGO_USERNAME=pippulse
MONGO_PASSWORD=your_secure_password_here

POSTGRES_USER=pippulse
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=pippulse

INFLUXDB_USERNAME=pippulse
INFLUXDB_PASSWORD=your_secure_password_here
INFLUXDB_ORG=pippulse
INFLUXDB_BUCKET=signals
# IMPORTANT: Generate a secure token in production!
INFLUXDB_TOKEN=your_influxdb_token_here

# API Keys - Get these from respective platforms
# News API: https://newsapi.org/register (Free tier: 100 requests/day)
NEWSAPI_KEY=your_newsapi_key_here

# Alpha Vantage API: https://www.alphavantage.co/
# Free tier: 5 calls/min, 500 calls/day (required for price data fetching)
ALPHAVANTAGE_API_KEY=your_alphavantage_key_here

# Twitter/X API: https://developer.twitter.com/en/portal/dashboard
# Free tier available for academic research
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here
TWITTER_API_KEY=your_twitter_api_key_here
TWITTER_API_SECRET=your_twitter_api_secret_here
TWITTER_ACCESS_TOKEN=your_twitter_access_token_here
TWITTER_ACCESS_SECRET=your_twitter_access_secret_here

# Reddit API: https://www.reddit.com/prefs/apps
# Create a script app for free access
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=PipPulse/1.0

# Telegram API: https://my.telegram.org/apps
# Get API ID and Hash for free
TELEGRAM_API_ID=your_telegram_api_id_here
TELEGRAM_API_HASH=your_telegram_api_hash_here
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Model Configuration
FINBERT_MODEL_NAME=ProsusAI/finbert

# Signal Generation Parameters
SIGNAL_LATENCY_TARGET=5
MAX_BATCH_SIZE=32
CONFIDENCE_THRESHOLD=0.6
TIME_DECAY_LAMBDA=0.1

# Source Credibility Weights (0-1)
SOURCE_WEIGHT_NEWSAPI=0.9
SOURCE_WEIGHT_TWITTER=0.7
SOURCE_WEIGHT_REDDIT=0.6
SOURCE_WEIGHT_TELEGRAM=0.5

# Time Windows (in minutes)
WINDOW_15MIN=15
WINDOW_1HOUR=60
WINDOW_4HOUR=240

# Currency Pairs to Monitor
CURRENCY_PAIRS=EUR/USD,GBP/USD,USD/JPY,USD/CHF,AUD/USD,USD/CAD,NZD/USD,USD/SGD

# Subreddits to Monitor
REDDIT_SUBREDDITS=Forex,CurrencyTrading,ForexStrategy,Daytrading

# Telegram Channels to Monitor (comma-separated)
TELEGRAM_CHANNELS=forex_signals,forex_trading

# News Categories
NEWS_CATEGORIES=business,general

# News Languages
NEWS_LANGUAGES=en

# Rate Limits (requests per minute)
RATE_LIMIT_NEWSAPI=100
RATE_LIMIT_TWITTER=450
RATE_LIMIT_REDDIT=60
RATE_LIMIT_TELEGRAM=30

# Backtesting Configuration
BACKTEST_START_DATE=2024-01-01
BACKTEST_END_DATE=2024-12-31
BACKTEST_INITIAL_CAPITAL=10000
BACKTEST_RISK_PER_TRADE=0.02

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# JWT Configuration
# IMPORTANT: Generate a strong secret key for production!
# Minimum 32 characters recommended
JWT_SECRET_KEY=your_jwt_secret_key_here_minimum_32_chars
